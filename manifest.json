{
  "manifest_version": 3,
  "name": "GC Multi-Acc Pro",
  "version": "1.0.0",
  "description": "Switch Gartic.io accounts instantly.",
  "permissions": ["cookies", "storage", "tabs"],
  "host_permissions": ["*://*.gartic.io/*"],
  "action": {
    "default_popup": "index.html"
  },
  "icons": {
    "16": "icon-16.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  }
}
